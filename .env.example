# ─────────────────────────────────────────────────────────────────────────────
# TaskGrid — Environment Variables
# Copy to backend/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev (SQLite — no Docker required):
DATABASE_URL=sqlite:///./data/taskgrid.db

# Local dev with Docker Compose PostgreSQL:
# DATABASE_URL=postgresql://taskgrid:taskgrid_secret@localhost:5432/taskgrid

# Production (replace with your actual credentials):
# DATABASE_URL=postgresql://taskgrid:<PASSWORD>@<HOST>:5432/taskgrid

# ── PostgreSQL connection pool (PostgreSQL only, ignored for SQLite) ──────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true
DB_POOL_RECYCLE=1800

# ── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: change SECRET_KEY to a random 32+ character string in production
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Admin seed user ───────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@taskgrid.io
ADMIN_PASSWORD=admin123
ADMIN_FULL_NAME=System Admin

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
